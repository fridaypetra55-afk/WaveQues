generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  wallet    String  @unique
  xp        Int     @default(0)
  streak    Int     @default(0)
  createdAt DateTime @default(now())
}

model Course {
  id   String @id @default(uuid())
  title String
  description String?
}
